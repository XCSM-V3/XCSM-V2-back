# Variables d'environnement pour Docker Compose
# Copier ce fichier vers .env et modifier les valeurs

# ==============================================================================
# DJANGO
# ==============================================================================
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ==============================================================================
# MYSQL
# ==============================================================================
MYSQL_ROOT_PASSWORD=rootpassword_change_me
DB_NAME=xcsm_db
DB_USER=xcsm_user
DB_PASSWORD=Xcsm@Password2025!

# ==============================================================================
# MONGODB
# ==============================================================================
MONGO_USER=admin
MONGO_PASSWORD=mongopassword_change_me

# ==============================================================================
# REDIS
# ==============================================================================
REDIS_URL=redis://redis:6379/0

# ==============================================================================
# GRAFANA
# ==============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin_change_me

# ==============================================================================
# OPENAI (Optionnel)
# ==============================================================================
OPENAI_API_KEY=your-openai-api-key-here
