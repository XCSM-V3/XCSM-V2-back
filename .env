# ========================================
# DJANGO CONFIGURATION
# ========================================
SECRET_KEY=django-insecure-xcsm-2025-change-this-in-production-abc123xyz789
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ========================================
# MYSQL DATABASE
# ========================================
DB_ENGINE=django.db.backends.mysql
DB_NAME=xcsm_db
DB_USER=xcsm_user
DB_PASSWORD=Xcsm@Password2025!
DB_HOST=localhost
DB_PORT=3306

# ========================================
# MONGODB
# ========================================
MONGO_URI=mongodb://localhost:27017/xcsm_granules_db
MONGO_DB_NAME=xcsm_granules_db
USE_MONGODB=True

# ========================================
# JWT AUTHENTICATION
# ========================================
JWT_SECRET_KEY=jwt-secret-key-super-secure-change-in-production-xyz789
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=86400

# ========================================
# CORS (Frontend)
# ========================================
FRONTEND_URL=http://localhost:3000
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ========================================
# FILE UPLOAD
# ========================================
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,docx,txt,html,md

# ========================================
# REDIS (Optionnel - pour Celery)
# ========================================
REDIS_URL=redis://localhost:6379/0
USE_REDIS=False

# ========================================
# EMAIL (Optionnel - pour notifications)
# ========================================
